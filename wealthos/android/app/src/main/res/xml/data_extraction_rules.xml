<?xml version="1.0" encoding="utf-8"?>
<!--
  WealthOS holds sensitive financial data locally. We opt out of cloud backup
  and device-to-device transfer so the encrypted-at-rest local database is never
  copied off the device by the platform. (Android 12+ uses these rules; older
  versions honour android:allowBackup="false".)
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
